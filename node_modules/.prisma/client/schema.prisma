generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum Role {
  OWNER
  ADMIN
  MEMBER
}

enum JobStatus {
  QUEUED
  SCHEDULED
  CLAIMED
  RUNNING
  COMPLETED
  FAILED
  RETRYING
  DEAD_LETTER
  CANCELLED
}

enum RetryStrategy {
  FIXED
  LINEAR
  EXPONENTIAL
}

model User {
  id           String               @id @default(uuid())
  email        String               @unique
  passwordHash String
  createdAt    DateTime             @default(now())
  memberships  OrganizationMember[]
}

model Organization {
  id        String               @id @default(uuid())
  name      String
  createdAt DateTime             @default(now())
  members   OrganizationMember[]
  projects  Project[]
}

model OrganizationMember {
  id             String       @id @default(uuid())
  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  organizationId String
  user           User         @relation(fields: [userId], references: [id], onDelete: Cascade)
  userId         String
  role           Role         @default(MEMBER)

  @@unique([organizationId, userId])
}

model Project {
  id             String       @id @default(uuid())
  name           String
  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  organizationId String
  createdAt      DateTime     @default(now())
  queues         Queue[]

  @@index([organizationId])
}

model RetryPolicy {
  id          String        @id @default(uuid())
  strategy    RetryStrategy @default(EXPONENTIAL)
  maxAttempts Int           @default(5)
  baseDelayMs Int           @default(1000)
  maxDelayMs  Int           @default(60000)
  queues      Queue[]
}

model Queue {
  id               String         @id @default(uuid())
  name             String
  project          Project        @relation(fields: [projectId], references: [id], onDelete: Cascade)
  projectId        String
  priority         Int            @default(0)
  concurrencyLimit Int            @default(5)
  isPaused         Boolean        @default(false)
  retryPolicy      RetryPolicy    @relation(fields: [retryPolicyId], references: [id])
  retryPolicyId    String
  createdAt        DateTime       @default(now())
  jobs             Job[]
  scheduledJobs    ScheduledJob[]

  @@unique([projectId, name])
  @@index([projectId])
}

model Job {
  id             String         @id @default(uuid())
  queue          Queue          @relation(fields: [queueId], references: [id], onDelete: Cascade)
  queueId        String
  payload        Json
  status         JobStatus      @default(QUEUED)
  priority       Int            @default(0)
  attempts       Int            @default(0)
  maxAttempts    Int            @default(5)
  scheduledAt    DateTime       @default(now())
  claimedAt      DateTime?
  startedAt      DateTime?
  completedAt    DateTime?
  workerId       String?
  worker         Worker?        @relation(fields: [workerId], references: [id])
  idempotencyKey String?
  createdAt      DateTime       @default(now())
  updatedAt      DateTime       @updatedAt
  executions     JobExecution[]
  logs           JobLog[]
  deadLetter     DeadLetterJob?

  @@index([queueId, status, priority, scheduledAt])
  @@index([idempotencyKey])
}

model JobExecution {
  id            String    @id @default(uuid())
  job           Job       @relation(fields: [jobId], references: [id], onDelete: Cascade)
  jobId         String
  attemptNumber Int
  worker        Worker?   @relation(fields: [workerId], references: [id])
  workerId      String?
  status        JobStatus
  startedAt     DateTime  @default(now())
  finishedAt    DateTime?
  errorMessage  String?
  durationMs    Int?

  @@index([jobId])
}

model JobLog {
  id        String   @id @default(uuid())
  job       Job      @relation(fields: [jobId], references: [id], onDelete: Cascade)
  jobId     String
  level     String
  message   String
  createdAt DateTime @default(now())

  @@index([jobId, createdAt])
}

model ScheduledJob {
  id              String    @id @default(uuid())
  queue           Queue     @relation(fields: [queueId], references: [id], onDelete: Cascade)
  queueId         String
  cronExpression  String
  payloadTemplate Json
  isActive        Boolean   @default(true)
  lastRunAt       DateTime?
  nextRunAt       DateTime?
  createdAt       DateTime  @default(now())

  @@index([isActive, nextRunAt])
}

model Worker {
  id         String            @id @default(uuid())
  hostname   String
  status     String            @default("ACTIVE")
  startedAt  DateTime          @default(now())
  jobs       Job[]
  executions JobExecution[]
  heartbeats WorkerHeartbeat[]
}

model WorkerHeartbeat {
  id          String   @id @default(uuid())
  worker      Worker   @relation(fields: [workerId], references: [id], onDelete: Cascade)
  workerId    String
  reportedAt  DateTime @default(now())
  runningJobs Int      @default(0)

  @@index([workerId, reportedAt])
}

model DeadLetterJob {
  id      String   @id @default(uuid())
  job     Job      @relation(fields: [jobId], references: [id], onDelete: Cascade)
  jobId   String   @unique
  reason  String
  movedAt DateTime @default(now())
}
